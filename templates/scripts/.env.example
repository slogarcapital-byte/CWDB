# CWDB ad-platform API credentials — example file
# Copy this file to .env.local at the REPO ROOT (not in templates/scripts/) and fill values.
# .env.local is gitignored. NEVER commit real credentials.
#
# Setup walkthrough: operations/automation/api-credentials/README.md

# ---------------------------------------------------------------------------
# Google Ads API (templates/scripts/pull-google-ads-mtd.ps1)
# ---------------------------------------------------------------------------
# Apply for the developer token at https://ads.google.com -> Tools -> API Center.
# Standard access typically takes 24-72 hours. Test access works for our own account.
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 client (Desktop app) credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Refresh token generated via the README's one-time consent flow
GOOGLE_ADS_REFRESH_TOKEN=

# CWDB Google Ads customer ID, digits only (no dashes). 712-991-0870 -> 7129910870
GOOGLE_ADS_CUSTOMER_ID=7129910870

# Manager (MCC) login customer ID, digits only. Leave blank if no MCC fronts the account.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ---------------------------------------------------------------------------
# Meta Marketing API (templates/scripts/pull-meta-ads-mtd.ps1)
# ---------------------------------------------------------------------------
# Long-lived System User access token from CWDB Meta Business Suite -> Business Settings ->
# System Users -> Generate New Token. Scopes: ads_read.
META_ACCESS_TOKEN=

# CWDB Meta ad account ID, digits only (no act_ prefix). The script adds it.
META_AD_ACCOUNT_ID=

# Optional. Defaults to v21.0 in the script.
META_API_VERSION=v21.0

# ---------------------------------------------------------------------------
# GA4 Data API (templates/scripts/pull-ga4-7d.ps1)
# ---------------------------------------------------------------------------
# Absolute path to the Service Account JSON key file (downloaded from Google Cloud Console).
# Store the file OUTSIDE the repo if possible (e.g., %USERPROFILE%\.cwdb\ga4-sa.json).
GA4_SERVICE_ACCOUNT_JSON=

# CWDB GA4 property ID. Confirmed 2026-04-25: 533582902 (measurement G-ZQ19JEF9KC).
GA4_PROPERTY_ID=533582902

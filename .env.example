# CWDB environment template. Copy to .env.local and fill in. NEVER commit .env.local.

# Google Ads API (warehouse pull + offline conversion upload)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Conversion action for JobTread signed jobs (Task 9; format customers/<cid>/conversionActions/<id>)
GOOGLE_ADS_JT_CONVERSION_ACTION=

# Meta Marketing API
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=

# Supabase warehouse (project iabiwsbmnbxmkjvkgfhg)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HubSpot (hybrid top-of-funnel; retire at JobTread cutover)
HUBSPOT_PRIVATE_APP_TOKEN=

# JobTread Pave API (grant created at app.jobtread.com/grants)
JOBTREAD_GRANT_KEY=
JOBTREAD_ORG_ID=

# QuickBooks Online (QBO_ENVIRONMENT selects sandbox|production)
QBO_ENVIRONMENT=
QBO_SANDBOX_CLIENT_ID=
QBO_SANDBOX_CLIENT_SECRET=
QBO_SANDBOX_REALM_ID=
QBO_SANDBOX_REFRESH_TOKEN=
QBO_PRODUCTION_CLIENT_ID=
QBO_PRODUCTION_CLIENT_SECRET=
QBO_PRODUCTION_REALM_ID=
QBO_PRODUCTION_REFRESH_TOKEN=

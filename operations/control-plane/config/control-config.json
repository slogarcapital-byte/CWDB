                 },
    "cadence":  {
                    "control_tick_minutes":  30,
                    "control_active_hours":  "06:00-22:00",
                    "orchestrator_tick_hours":  2,
                    "orchestrator_active_hours":  "07:00-21:00",
                    "digest_hour_local":  7
                },
    "data_freshness":  {
                           "_comment":  "Gate stays closed if the warehouse cron hasn\u0027t succeeded within this window - never reason on stale funnel data.",
                           "warehouse_max_age_hours":  26
                       },
    "tiers":  {

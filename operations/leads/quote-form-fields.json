{
  "form": {
    "platform": "Tally",
    "name": "CWDB Deck Quote Request",
    "description": "Homeowner intake form embedded on landing pages. Triggers Make webhook on submission.",
    "fields": [
      {
        "id": 1,
        "label": "Full Name",
        "type": "short_text",
        "required": true,
        "placeholder": "Your full name"
      },
      {
        "id": 2,
        "label": "Phone Number",
        "type": "phone",
        "required": true,
        "placeholder": "(715) 555-0000",
        "validation": "US phone format"
      },
      {
        "id": 3,
        "label": "Email Address",
        "type": "email",
        "required": true,
        "placeholder": "you@email.com"
      },
      {
        "id": 4,
        "label": "Property Address",
        "type": "short_text",
        "required": true,
        "placeholder": "Street address, City, WI ZIP"
      },
      {
        "id": 5,
        "label": "Do you own this property?",
        "type": "multiple_choice",
        "required": true,
        "options": ["Yes, I own this home", "No, I rent"]
      },
      {
        "id": 6,
        "label": "What type of project is this?",
        "type": "multiple_choice",
        "required": true,
        "options": [
          "New deck build",
          "Deck replacement",
          "Deck repair",
          "Deck addition / expansion",
          "Not sure yet"
        ]
      },
      {
        "id": 7,
        "label": "What is your estimated budget?",
        "type": "multiple_choice",
        "required": true,
        "options": [
          "Under $5,000",
          "$5,000 – $10,000",
          "$10,000 – $20,000",
          "$20,000 – $40,000",
          "$40,000+"
        ]
      },
      {
        "id": 8,
        "label": "When are you looking to start?",
        "type": "multiple_choice",
        "required": true,
        "options": [
          "As soon as possible",
          "Within 1–3 months",
          "3–6 months",
          "Just planning ahead"
        ]
      },
      {
        "id": 9,
        "label": "Anything else we should know about your project?",
        "type": "long_text",
        "required": false,
        "placeholder": "Deck size, materials, special features, etc."
      }
    ],
    "post_submit": {
      "message": "Thanks! A local contractor will reach out within 24 hours.",
      "webhook_trigger": true,
      "webhook_destination": "/operations/make/webhooks.json"
    }
  }
}

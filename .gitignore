# Claude IDE local settings
.claude/settings.local.json

# Environment / secrets
.env
.env.local
*.env
env.local
**/env.local

# Data warehouse output artifacts (pull script snapshots + logs + cron logs)
_vault/data/*-warehouse-*.json
_vault/data/*-warehouse-*.log
_vault/data/hubspot-latest.json
_vault/data/hubspot-error.log
_vault/data/cron-runs.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor artifacts
.vscode/
*.swp
*~

# Node (if added later)
node_modules/

# Generated reports and P&L outputs (optional — uncomment to exclude)
# finance/pl/*.xlsx
# finance/reports/**/*.xlsx

# Python artifacts
__pycache__/
*.pyc
*.pyo

# Customer PII — date-prefixed estimate JSONs contain real homeowner info
# (test-inputs-*.json fixtures stay versioned)
sales/estimates/_data/[0-9]*.json
sales/estimates/*.pdf

# Streamlit secrets (defense-in-depth; streamlit_app/.gitignore also covers this)
**/.streamlit/secrets.toml
